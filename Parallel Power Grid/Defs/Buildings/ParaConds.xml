	<ThingDef ParentName="ParaBuilding">
		<defName>ParaCondSocket</defName>	
		<thingClass>Parallel_PowerGrid.ParaBuilding</thingClass>		
		<label>parallel conduit socket (All)</label>
		<description>A Socket that can be used to connect parallel conduits to normal conduits. Can be placed under walls and other buildings.</description>
		<graphicData>
			<texPath>Things/ParallelPowerGrid/ParaSocket_Atlas</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<linkType>Basic</linkType>
			<linkFlags>
				<li>4096</li>
				<li>8192</li>					
				<li>16384</li>				
				<li>PowerConduit</li>
			</linkFlags>
			<damageData>
				<rect>(0,0.35,1,0.3)</rect>
			</damageData>
		</graphicData>
		<building>
			<ai_chillDestination>false</ai_chillDestination>
			<isInert>true</isInert>
			<isEdifice>false</isEdifice>
			<blueprintGraphicData>
				<texPath>Things/ParallelPowerGrid/ParaSocket_AtlasBP</texPath>
				<graphicClass>Graphic_Single</graphicClass>
				<linkType>Basic</linkType>
				<linkFlags>
					<li>4096</li>
					<li>8192</li>	
					<li>16384</li>
					<li>PowerConduit</li>
				</linkFlags>
			</blueprintGraphicData>			
			<blueprintClass>Parallel_PowerGrid.Blueprint_Show</blueprintClass>
		</building>
		<costList>
			<Wire>4</Wire>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>
		<uiIconPath>Things/ParallelPowerGrid/ParaSocket</uiIconPath>
		<comps>
			<li Class="Parallel_PowerGrid.CompProperties_ParaPower">
				<compClass>Parallel_PowerGrid.Comp_ParaTransmitter</compClass>   
				<startElectricalFires>false</startElectricalFires>
				<Layer>-1</Layer>
			</li>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTransmitter</compClass>
				<transmitsPower>true</transmitsPower> 		
			</li>	  
		</comps>
	</ThingDef>
	
